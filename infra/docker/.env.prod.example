NODE_ENV=production
PMTL_DOMAIN=example.com
PMTL_CMS_DOMAIN=cms.example.com
NEXT_PUBLIC_SITE_URL=https://example.com
CMS_PUBLIC_URL=https://cms.example.com
PAYLOAD_PUBLIC_SERVER_URL=https://cms.example.com
PAYLOAD_SECRET=replace-with-prod-secret
AUTH_RESET_PASSWORD_URL=https://example.com/reset-password
PAYLOAD_AUTH_DISABLE_EMAIL=false
POSTGRES_DB=pmtl
POSTGRES_USER=pmtl
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://pmtl:replace-with-strong-password@postgres:5432/pmtl
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=replace-with-prod-meili-key
INTERNAL_WEBHOOK_URL=
WEB_IMAGE=ghcr.io/quyenvjp/pmtl-vn-web:latest
CMS_IMAGE=ghcr.io/quyenvjp/pmtl-vn-cms:latest

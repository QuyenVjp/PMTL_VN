NODE_ENV=production
PMTL_DOMAIN=example.com
PMTL_CMS_DOMAIN=cms.example.com
NEXT_PUBLIC_SITE_URL=https://example.com
CMS_PUBLIC_URL=https://cms.example.com
PAYLOAD_PUBLIC_SERVER_URL=https://cms.example.com
PAYLOAD_SECRET=replace-with-prod-secret
AUTH_RESET_PASSWORD_URL=https://example.com/reset-password
PAYLOAD_AUTH_DISABLE_EMAIL=false
POSTGRES_DB=pmtl
POSTGRES_USER=pmtl
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://pmtl:replace-with-strong-password@postgres:5432/pmtl
PAYLOAD_DB_PUSH=false
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=replace-with-prod-meili-key
MEILI_ENV=production
MEILI_SCHEDULE_SNAPSHOT=true
MEILI_SNAPSHOT_DIR=/meili_data/snapshots
INTERNAL_WEBHOOK_URL=
REDIS_URL=redis://redis:6379
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PMTL_VN
WORKER_MAINTENANCE_INTERVAL_MS=600000
WORKER_HEARTBEAT_PATH=/var/run/pmtl/worker-heartbeat.json
WORKER_HEARTBEAT_STALE_SECONDS=120
WEB_IMAGE=ghcr.io/quyenvjp/pmtl-vn-web:replace-with-release-tag
CMS_IMAGE=ghcr.io/quyenvjp/pmtl-vn-cms:replace-with-release-tag
MONITORING_PROMETHEUS_IMAGE=prom/prometheus:latest
MONITORING_ALERTMANAGER_IMAGE=prom/alertmanager:latest
MONITORING_GRAFANA_IMAGE=grafana/grafana:latest
MONITORING_BLACKBOX_IMAGE=quay.io/prometheus/blackbox-exporter:latest
MONITORING_POSTGRES_EXPORTER_IMAGE=quay.io/prometheuscommunity/postgres-exporter:latest
MONITORING_REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:latest
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3300
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_RETENTION_SIZE=512MB
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
GRAFANA_ROOT_URL=http://127.0.0.1:3300
ALERT_TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
ALERT_TELEGRAM_CHAT_ID=replace-with-telegram-chat-id

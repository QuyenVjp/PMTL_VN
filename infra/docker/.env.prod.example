NODE_ENV=production
PMTL_DOMAIN=phapmontamlinh-quantheambotat.vn
PMTL_CMS_DOMAIN=cms.phapmontamlinh-quantheambotat.vn
NEXT_PUBLIC_SITE_URL=https://phapmontamlinh-quantheambotat.vn
CMS_PUBLIC_URL=https://cms.phapmontamlinh-quantheambotat.vn
PAYLOAD_PUBLIC_SERVER_URL=https://cms.phapmontamlinh-quantheambotat.vn
PAYLOAD_SECRET=replace-with-prod-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_RESET_PASSWORD_URL=https://phapmontamlinh-quantheambotat.vn/reset-password
PAYLOAD_AUTH_DISABLE_EMAIL=false
POSTGRES_DB=pmtl
POSTGRES_USER=pmtl
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://pmtl:replace-with-strong-password@pgbouncer:5432/pmtl
PAYLOAD_DB_PUSH=false
PAYLOAD_DB_POOL_MAX=50
PAYLOAD_DB_POOL_MIN=5
PAYLOAD_DB_POOL_IDLE_TIMEOUT_MS=30000
PAYLOAD_DB_POOL_CONN_TIMEOUT_MS=10000
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=2000
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_RESERVE_POOL_SIZE=10
PGBOUNCER_SERVER_IDLE_TIMEOUT=30
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=replace-with-prod-meili-key
MEILI_ENV=production
MEILI_SCHEDULE_SNAPSHOT=86400
MEILI_SNAPSHOT_DIR=/meili_data/snapshots
INTERNAL_WEBHOOK_URL=
REDIS_URL=redis://redis:6379
CSRF_SECRET=replace-with-long-random-csrf-secret
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PMTL_VN
WORKER_MAINTENANCE_INTERVAL_MS=600000
WORKER_STARTUP_RETRY_COUNT=0
WORKER_STARTUP_RETRY_DELAY_MS=3000
WORKER_HEARTBEAT_PATH=/var/run/pmtl/worker-heartbeat.json
WORKER_HEARTBEAT_STALE_SECONDS=120
WEB_IMAGE=ghcr.io/quyenvjp/pmtl-vn-web:replace-with-release-tag
CMS_IMAGE=ghcr.io/quyenvjp/pmtl-vn-cms:replace-with-release-tag
MONITORING_PROMETHEUS_IMAGE=prom/prometheus:v3.5.1
MONITORING_ALERTMANAGER_IMAGE=prom/alertmanager:v0.29.0
MONITORING_GRAFANA_IMAGE=grafana/grafana:12.0.1
MONITORING_BLACKBOX_IMAGE=quay.io/prometheus/blackbox-exporter:v0.28.0
MONITORING_POSTGRES_EXPORTER_IMAGE=quay.io/prometheuscommunity/postgres-exporter:v0.18.1
MONITORING_REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:v1.72.1
MONITORING_NODE_EXPORTER_IMAGE=quay.io/prometheus/node-exporter:v1.10.2
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3300
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_RETENTION_SIZE=512MB
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
GRAFANA_ROOT_URL=http://127.0.0.1:3300
ALERT_TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
ALERT_TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
SENTRY_ENABLED=true
NEXT_PUBLIC_SENTRY_ENABLED=true
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=0
SENTRY_WORKER_TRACES_SAMPLE_RATE=0.05
MONITORING_TEST_SECRET=replace-with-strong-monitoring-test-secret

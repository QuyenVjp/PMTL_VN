NODE_ENV=development

# Shared
PMTL_DOMAIN=localhost
PMTL_CMS_DOMAIN=cms.localhost
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CMS_PUBLIC_URL=http://localhost:3001
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
PAYLOAD_SECRET=replace-with-a-long-random-string
AUTH_RESET_PASSWORD_URL=http://localhost:3000/reset-password
PAYLOAD_AUTH_DISABLE_EMAIL=true

# Database
POSTGRES_DB=pmtl
POSTGRES_USER=pmtl
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://pmtl:replace-with-a-strong-password@postgres:5432/pmtl

# Search
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=replace-with-a-strong-meili-key

# Stage 2
REDIS_URL=redis://redis:6379

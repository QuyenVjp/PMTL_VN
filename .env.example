NODE_ENV=development

# Shared
PMTL_DOMAIN=localhost
PMTL_CMS_DOMAIN=cms.localhost
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SECURITY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SECURITY_RATE_LIMIT_STORE=auto
SECURITY_RATE_LIMIT_MAX=120
SECURITY_RATE_LIMIT_WINDOW_MS=60000
SECURITY_RATE_LIMIT_AUTH_MAX=15
SECURITY_RATE_LIMIT_AUTH_WINDOW_MS=60000
SECURITY_RATE_LIMIT_UPLOAD_MAX=20
SECURITY_RATE_LIMIT_UPLOAD_WINDOW_MS=300000
CMS_PUBLIC_URL=http://localhost:3001
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
PAYLOAD_API_TOKEN=
PAYLOAD_SECRET=replace-with-a-long-random-string
INTERNAL_WEBHOOK_URL=http://web:3000/api/revalidate
REVALIDATE_SECRET=replace-with-a-long-random-string
AUTH_RESET_PASSWORD_URL=http://localhost:3000/reset-password
PAYLOAD_AUTH_DISABLE_EMAIL=true

# Database
POSTGRES_DB=pmtl
POSTGRES_USER=pmtl
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://pmtl:replace-with-a-strong-password@postgres:5432/pmtl
PAYLOAD_DB_PUSH=false

# Search
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=replace-with-a-strong-meili-key
MEILISEARCH_BLOG_POST_INDEX=posts
MEILI_POSTS_INDEX=posts
MEILI_SEMANTIC_EMBEDDER=default
MEILI_SEMANTIC_DIMENSIONS=1536
MEILI_SEMANTIC_RATIO=0.35
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Production infrastructure
REDIS_URL=redis://redis:6379
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PMTL_VN
WORKER_MAINTENANCE_INTERVAL_MS=600000

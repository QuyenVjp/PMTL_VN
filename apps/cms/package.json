{
  "name": "@pmtl/cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "tsx ../../infra/scripts/ensure-port-free.ts 3001 cms",
    "dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts next dev --webpack --port 3001",
    "worker:dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts PAYLOAD_DB_PUSH=false tsx watch src/workers/index.ts",
    "worker:start": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts PAYLOAD_DB_PUSH=false tsx src/workers/index.ts",
    "build": "pnpm run generate:types && pnpm run generate:importmap && next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "pnpm run generate:types && pnpm run generate:importmap && tsc --noEmit",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:importmap",
    "migrate": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate",
    "db:sync": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts PAYLOAD_DB_PUSH=true tsx src/scripts/sync-schema.ts",
    "reindex:posts": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts PAYLOAD_DB_PUSH=false tsx src/scripts/reindex-posts.ts --all-pages",
    "seed:demo": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts PAYLOAD_DB_PUSH=false tsx src/scripts/seed-demo.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.79.0",
    "@payloadcms/next": "3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/translations": "^3.79.0",
    "@pmtl/shared": "workspace:*",
    "@sentry/nextjs": "10.43.0",
    "@sentry/node": "10.43.0",
    "cross-env": "^10.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "meilisearch": "^0.55.0",
    "next": "16.1.6",
    "nodemailer": "^7.0.10",
    "payload": "^3.79.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^10.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.2",
    "@types/web-push": "^3.6.4"
  }
}

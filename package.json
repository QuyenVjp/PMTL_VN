{
  "name": "pmtl-vn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=10.30.3"
  },
  "scripts": {
    "dev": "tsx infra/scripts/dev.ts",
    "dev:apps": "turbo run dev --parallel --filter=@pmtl/web --filter=@pmtl/cms",
    "dev:worker": "pnpm --filter @pmtl/cms worker:dev",
    "dev:web": "pnpm --filter @pmtl/web dev",
    "dev:cms": "pnpm --filter @pmtl/cms dev",
    "dev:infra": "tsx infra/scripts/dev.ts --infra-only",
    "dev:infra:down": "docker compose -f infra/docker/compose.dev.yml down",
    "db:reset:dev": "tsx infra/scripts/reset-dev-db.ts",
    "seed:demo": "pnpm --filter @pmtl/cms seed:demo",
    "seed:demo:reset": "pnpm --filter @pmtl/cms seed:demo:reset",
    "reindex:posts": "pnpm --filter @pmtl/cms reindex:posts",
    "smoke:test": "tsx infra/scripts/smoke-test.ts",
    "monitoring:test": "tsx infra/scripts/test-monitoring.ts",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "pnpm --filter @pmtl/cms test && pnpm --filter @pmtl/web test",
    "test:web": "pnpm --filter @pmtl/web test",
    "test:cms": "pnpm --filter @pmtl/cms test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "docker:dev": "docker compose -f infra/docker/compose.dev.yml up --build",
    "docker:prod": "docker compose -f infra/docker/compose.prod.yml up -d"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@rolldown/binding-win32-x64-msvc": "1.0.0-rc.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.35.0",
    "eslint-config-next": "^16.1.6",
    "globals": "^16.4.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.0",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}

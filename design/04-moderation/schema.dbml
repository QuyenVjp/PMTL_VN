// Moderation Module - logical schema aligned with current repo truth
// Note:
// - moderation_reports là source of truth.
// - Các table target bên dưới chỉ xuất hiện ở đây để mô tả summary sync,
//   không chuyển ownership của chúng sang moderation module.

Project moderation_module {
  database_type: "PostgreSQL"
  Note: '''
  Moderation module cho PMTL_VN.
  Ghi nhớ:
  - moderation_reports là record gốc.
  - các bảng comment, community_posts, guestbook_entries bên dưới chỉ được nhắc tới để mô tả field summary.
  '''
}

Enum moderation_report_status {
  pending
  approved
  rejected
  flagged
  hidden
}

Table users {
  id uuid [pk]
  public_id varchar [unique]
  full_name varchar
  email varchar
}

Table moderation_reports {
  id uuid [pk]
  public_id varchar [unique]
  entity_type varchar [not null] // postComments | communityPosts | communityComments | guestbookEntries
  entity_public_id varchar [not null]
  entity_collection varchar
  entity_document_id varchar
  reason varchar [not null]
  notes text
  status moderation_report_status [not null]
  reporter_user_id uuid [ref: > users.id]
  reporter_ip_hash varchar
  created_at timestamp
  updated_at timestamp
}

Table post_comments {
  id uuid [pk]
  public_id varchar [unique]
  moderation_status varchar
  report_count int
  last_report_reason varchar
  is_hidden bool
}

Table community_posts {
  id uuid [pk]
  public_id varchar [unique]
  moderation_status varchar
  report_count int
  last_report_reason varchar
  is_hidden bool
}

Table community_comments {
  id uuid [pk]
  public_id varchar [unique]
  moderation_status varchar
  report_count int
  last_report_reason varchar
  is_hidden bool
}

Table guestbook_entries {
  id uuid [pk]
  public_id varchar [unique]
  approval_status varchar
}

TableGroup "Moderation Source of Truth" [note: "Bảng gốc cần đọc đầu tiên khi điều tra report"] {
  moderation_reports
}

TableGroup "Moderated Targets" [note: "Entity bị ảnh hưởng bởi decision và summary sync"] {
  post_comments
  community_posts
  community_comments
  guestbook_entries
}

TableGroup "Actor Reference" [note: "Người report hoặc người bị ảnh hưởng"] {
  users
}

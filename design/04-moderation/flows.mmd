flowchart TD
    subgraph Flow1 ["Luồng 1: Tạo phiếu báo cáo kiểm duyệt"]
        M1A["Người dùng report một entity"] --> M1B["Tìm entity đích theo publicId"]
        M1B --> M1C["Tạo moderationReports"]
        M1C --> M1D["Lưu entityType, entityPublicId, entityRef, lý do, và người report"]
        M1D --> M1E["Đồng bộ reportCount và lastReportReason lên entity đích"]
        M1E --> M1F["Đưa cảnh báo vào hàng chờ cho admin hoặc super-admin"]
    end

    subgraph Flow2 ["Luồng 2: Người kiểm duyệt ra quyết định"]
        M2A["Moderator mở report"] --> M2B["Chọn decision (quyết định)"]
        M2B --> M2C["Cập nhật status của moderation report"]
        M2C --> M2D{"Loại target"}
        M2D -->|"comment hoặc community post"| M2E["Đặt moderationStatus và isHidden"]
        M2D -->|"guestbook"| M2F["Đặt approvalStatus"]
        M2E --> M2G["Thông báo người dùng liên quan nếu có"]
        M2F --> M2G
    end

    subgraph Flow3 ["Luồng 3: Đường kiểm duyệt guestbook"]
        M3A["Guestbook entry đang pending hoặc bị report"] --> M3B["Moderator xem entry"]
        M3B --> M3C{"Decision"}
        M3C -->|"approved"| M3D["approvalStatus = approved"]
        M3C -->|"rejected"| M3E["approvalStatus = rejected"]
        M3D --> M3F["Entry được hiển thị public"]
        M3E --> M3G["Entry không hiển thị public"]
    end

    M1F -.->|"tiếp"| M2A
    M2G -.->|"tiếp"| M3A

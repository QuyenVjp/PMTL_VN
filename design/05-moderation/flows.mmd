flowchart TD
    subgraph Flow1 ["Luồng 1: Tạo phiếu báo cáo kiểm duyệt (Create Moderation Report)"]
        M1A["Người dùng trình báo thực thể (User reports entity)"] --> M1B["Tìm thực thể đích (Find target by publicId)"]
        M1B --> M1C["Khởi tạo báo cáo (Create moderationReports)"]
        M1D["Lưu loại, ID, lý do & người báo (Save type, ID, reason & reporter)"]
        M1C --> M1D
        M1E["Đồng bộ số lượng & lý do lên đích (Sync count & reason to target)"]
        M1D --> M1E
        M1F["Thêm cảnh báo cho quản trị viên (Append alert for admin)"]
        M1E --> M1F
    end

    M1F -.->|"tiếp (then)"| M2A

    subgraph Flow2 ["Luồng 2: Người thực hiện ra quyết định (Moderator Decision)"]
        M2A["Mở phiếu báo cáo (Moderator opens report)"] --> M2B["Lựa chọn quyết định (Select decision)"]
        M2B --> M2C["Cập nhật trạng thái báo cáo (Update report status)"]
        M2C --> M2D{"Phân loại thực thể (Target type?)"}
        M2D -->|"Bình luận/Cộng đồng (Comment/Community)"| M2E["Đặt trạng thái & tính ẩn (Set status & isHidden)"]
        M2D -->|"Lưu niệm (Guestbook)"| M2F["Đặt trạng thái phê duyệt (Set approvalStatus)"]
        M2G["Thông báo cho người liên quan (Notify affected users)"]
        M2E --> M2G
        M2F --> M2G
    end

    M2G -.->|"tiếp (then)"| M3A

    subgraph Flow3 ["Luồng 3: Quy trình duyệt sổ lưu niệm (Guestbook Approval)"]
        M3A["Lời nhắn đang chờ hoặc bị báo cáo (Entry pending or reported)"] --> M3B["Xem nội dung lời nhắn (Moderator views entry)"]
        M3B --> M3C{"Quyết định? (Decision?)"}
        M3C -->|"Chấp nhận (Approved)"| M3D["Cập nhật trạng thái Chấp nhận (Set approved)"]
        M3C -->|"Từ chối (Rejected)"| M3E["Cập nhật trạng thái Từ chối (Set rejected)"]
        M3F["Hiển thị công khai (Publicly visible)"]
        M3D --> M3F
        M3G["Không hiển thị công khai (Hidden from public)"]
        M3E --> M3G
    end

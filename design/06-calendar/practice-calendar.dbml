Project practice_calendar_schema {
  database_type: "PostgreSQL"
  Note: "Optional rule layer va read model cho Lich tu hoc ca nhan / personal practice calendar."
}

Enum practice_calendar_rule_type {
  monthly_day
  bodhisattva_day
  vegetarian_day
  golden_hour
}

Table practice_calendar_rules {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  rule_type practice_calendar_rule_type [not null]
  title varchar(160) [not null]
  description text
  lunar_month int
  lunar_day int
  solar_fallback_rule varchar(160)
  time_window_start time
  time_window_end time
  priority int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table personal_practice_calendar_read_model {
  id uuid [pk]
  public_id varchar(32) [not null, unique, note: "Public ID / ma cong khai"]
  user_id uuid [note: "Nullable neu la public preset, co gia tri neu la personal view"]
  calendar_date date [not null, note: "Ngay duong lich / solar date"]
  lunar_label varchar(120) [note: "Nhan am lich / lunar label"]
  day_tags jsonb [not null, note: "Ngay via, trai gioi, phong sanh, golden hour"]
  recommended_items jsonb [note: "Danh sach bai nen doc/niem"]
  recommended_windows jsonb [note: "Khung gio goi y / recommended practice windows"]
  vow_hooks jsonb [note: "Lien ket nguyen luc / vow hooks"]
  life_release_hooks jsonb [note: "Lien ket phong sanh / life release hooks"]
  source_version varchar(64)
  generated_at timestamptz [not null]
}

// Calendar Module - logical schema (lược đồ logic) aligned with current repo truth (hiện trạng repo)

Project calendar_module {
  database_type: "PostgreSQL"
  Note: '''
  Calendar module (module lịch và lịch tu học) cho PMTL_VN.
  Gợi ý đọc:
  - events = sự kiện công khai.
  - lunar_events = lịch âm gốc.
  - lunar_event_overrides = lớp điều chỉnh hoặc gắn practice rule.
  - practice_calendar_rules và personal_practice_calendar_read_model = lớp lịch tu học cá nhân.
  '''
}

Enum event_status_enum {
  upcoming
  live
  past
}

Table media_assets {
  id uuid [pk]
  public_id varchar [unique]
  storage_provider varchar [not null, note: "local | s3-compatible"]
  object_key varchar [unique, not null]
  original_filename varchar
  content_type varchar
  size_bytes bigint
  checksum_sha256 varchar
  owner_id uuid
  created_at timestamp
  updated_at timestamp
}

Table posts {
  id uuid [pk]
  public_id varchar [unique]
  title varchar
}

Table chant_items {
  id uuid [pk]
  public_id varchar [unique]
  title varchar
}

Table events {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  slug varchar [unique, not null]
  description text [not null]
  content jsonb
  date timestamp [not null]
  time_string varchar
  location varchar
  type varchar [not null] // ceremony | retreat | talk | livestream
  speaker varchar
  language varchar
  external_link varchar
  youtube_id varchar
  embed_url varchar
  cover_image_id uuid [ref: > media_assets.id]
  event_status event_status_enum [not null]
  created_at timestamp
  updated_at timestamp
}

Table event_gallery_media {
  event_id uuid [ref: > events.id]
  media_id uuid [ref: > media_assets.id]

  indexes {
    (event_id, media_id) [pk]
  }
}

Table event_files {
  event_id uuid [ref: > events.id]
  media_id uuid [ref: > media_assets.id]

  indexes {
    (event_id, media_id) [pk]
  }
}

Table lunar_events {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  lunar_month int
  lunar_day int
  is_leap_month bool [default: false]
  event_type varchar
  priority int [default: 0]
  created_at timestamp
  updated_at timestamp
}

Table lunar_event_related_posts {
  lunar_event_id uuid [ref: > lunar_events.id]
  post_id uuid [ref: > posts.id]

  indexes {
    (lunar_event_id, post_id) [pk]
  }
}

Table lunar_event_overrides {
  id uuid [pk]
  public_id varchar [unique]
  lunar_event_id uuid [not null, ref: > lunar_events.id]
  chant_item_id uuid [not null, ref: > chant_items.id]
  mode varchar
  target int
  max int
  priority int [default: 0]
  note text
  created_at timestamp
  updated_at timestamp
}

Enum practice_calendar_rule_type {
  monthly_day
  bodhisattva_day
  vegetarian_day
  golden_hour
}

Table practice_calendar_rules {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  rule_type practice_calendar_rule_type [not null]
  title varchar(160) [not null]
  description text
  lunar_month int
  lunar_day int
  solar_fallback_rule varchar(160) [note: "Quy tắc lui về dương lịch nếu không tính được âm lịch"]
  time_window_start time
  time_window_end time
  priority int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "Rule layer (lớp quy tắc) cho ngày tu học, ngày vía, ngày trai giới, và giờ gợi ý."
}

Table personal_practice_calendar_read_model {
  id uuid [pk]
  public_id varchar(32) [not null, unique, note: "Public ID (mã công khai)"]
  user_id uuid [note: "Nullable (có thể rỗng) nếu là public preset; có giá trị nếu là personal view (góc nhìn cá nhân)"]
  calendar_date date [not null, note: "Ngày dương lịch / solar date"]
  lunar_label varchar(120) [note: "Nhãn âm lịch / lunar label"]
  day_tags jsonb [not null, note: "Ngày vía, trai giới, phóng sanh, golden hour (khung giờ gợi ý tốt)"]
  recommended_items jsonb [note: "Danh sách bài nên đọc hoặc niệm"]
  recommended_windows jsonb [note: "Khung giờ gợi ý / recommended practice windows"]
  vow_hooks jsonb [note: "Liên kết phát nguyện / vow hooks"]
  life_release_hooks jsonb [note: "Liên kết phóng sanh / life release hooks"]
  advisory_cards jsonb [note: "Thông báo tu học rút gọn / concise daily practice advisory cards"]
  source_refs jsonb [note: "Link bài gốc, bài dịch, và community support refs (tham chiếu hỗ trợ từ cộng đồng)"]
  source_version varchar(64)
  generated_at timestamptz [not null]
}

TableGroup "Event Publishing" [note: "Nhóm sự kiện public"] {
  events
  event_gallery_media
  event_files
}

TableGroup "Lunar Calendar" [note: "Nhóm dữ liệu lịch âm"] {
  lunar_events
  lunar_event_related_posts
  lunar_event_overrides
  practice_calendar_rules
  personal_practice_calendar_read_model
}

TableGroup "Shared References" [note: "Dữ liệu tham chiếu dùng để liên kết"] {
  media_assets
  posts
  chant_items
}

graph TD
    subgraph "Điều phối truy cập (Ingress & Reverse Proxy)"
        Caddy["Caddy<br/>Proxy đảo / HTTPS (Reverse Proxy)"]
    end

    subgraph "Giao diện (Frontend)"
        Web["apps/web<br/>Next.js App Router (User UI)"]
    end

    subgraph "Môi trường API (Backend Runtime)"
        API["apps/api<br/>NestJS API + Định danh (Auth & Domain)"]
        Compat["Lớp tương thích & Ánh xạ DTO<br/>(Compatibility & DTO Layer)"]
        Proxy["Ranh giới Web Proxy / Phiên<br/>(Request & Session Boundary)"]
    end

    subgraph "Xử lý bất đồng bộ (Async & Queue Runtime)"
        Valkey["Valkey<br/>Bộ nhớ đệm + Hàng đợi (Cache & Queue)"]
        Worker["Worker<br/>Tìm kiếm / Thông báo / Email / Bảo trì"]
    end

    subgraph "Dữ liệu (Data & Persistence)"
        Postgres["PostgreSQL<br/>Nguồn dữ liệu chuẩn (Source of Truth)"]
        Meili["Meilisearch<br/>Chỉ dành cho tìm kiếm (Search indexing)"]
    end

    subgraph "Giám sát & Điều phối (Optional Ops Stack)"
        PgBouncer["PgBouncer<br/>(Connection Pooling)"]
        Prometheus["Prometheus<br/>(Metrics Collection)"]
        Grafana["Grafana<br/>(Visualization)"]
        Alertmanager["Alertmanager<br/>(Alert Routing)"]
    end

    Caddy --> Web
    Caddy --> API

    Web --> Proxy
    Proxy --> Compat
    Compat --> API

    API -->|Đọc/Ghi dữ liệu chuẩn (Read/Write Canonical)| Postgres
    API -->|Đệm / Hàng đợi (Cache / Queue push)| Valkey
    Worker -->|Lấy việc (Pull jobs)| Valkey
    Worker -->|Mục tiêu dữ liệu chuẩn (Canonical Update)| Postgres
    Worker -->|Đẩy chỉ mục (Push indices)| Meili

    API -->|Truy vấn tìm kiếm (Search query)| Meili
    Web -->|Tìm kiếm qua API (Public Search via API)| Compat

    API -. Tùy chọn .-> PgBouncer
    PgBouncer -. Điều phối kết nối .-> Postgres

    Web -. Chỉ số/Nhật ký (Metrics/Logs) .-> Prometheus
    API -. Chỉ số/Nhật ký (Metrics/Logs) .-> Prometheus
    Worker -. Chỉ số/Nhật ký (Metrics/Logs) .-> Prometheus
    Prometheus --> Grafana
    Prometheus --> Alertmanager

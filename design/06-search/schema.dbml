// Search Module - logical schema (lược đồ logic) aligned with current repo truth (hiện trạng repo)
// Note:
// - `outbox_events` thuộc platform control-plane; file này chỉ tham chiếu tới luồng handoff chuẩn đó.
// - `search_sync_jobs` là execution queue artifact (dấu vết chạy lúc runtime), không phải source of truth (nguồn dữ liệu gốc).
// - `meilisearch_posts_index` là computed index document (bản ghi chỉ mục được tính ra).
// - `posts_search_source` biểu diễn source fields (các trường nguồn) thực lấy từ content module.

Project search_module {
  database_type: "PostgreSQL"
  Note: '''
  Search module cho PMTL_VN.
  Cách đọc:
  - posts_search_source = dữ liệu gốc đem đi index.
  - outbox_events = event log chuẩn cho handoff khỏi canonical write, được định nghĩa ở schema control-plane.
  - search_sync_jobs = hàng chờ thực thi, không phải dữ liệu nghiệp vụ gốc.
  - meilisearch_posts_index = bản sao để tìm kiếm nhanh.
  '''
}

Enum search_job_status {
  queued
  active
  completed
  failed
}

Table posts_search_source {
  document_id uuid [pk]
  public_id varchar [unique]
  slug varchar [not null]
  title varchar [not null]
  source_ref varchar
  excerpt text
  content_plain_text text
  normalized_search_text text
  topic varchar
  published_at timestamp
  featured bool [default: false]
  views int [default: 0]
}

Table post_search_source_tags {
  document_id uuid [ref: > posts_search_source.document_id]
  tag_value varchar

  indexes {
    (document_id, tag_value) [pk]
  }
}

Table search_sync_jobs {
  job_id varchar [pk]
  queue_name varchar [not null] // search-sync
  outbox_event_id uuid [note: "Ref (tham chiếu) tới 00-identity.outbox_events.event_id"]
  document_id uuid
  public_id varchar
  status search_job_status [not null]
  attempts int [default: 0]
  enqueued_at timestamp
  processed_at timestamp
  finished_at timestamp
  error_summary text
}

// Computed search document stored in Meilisearch.
Table meilisearch_posts_index {
  document_id uuid [pk]
  public_id varchar [unique]
  slug varchar
  title varchar
  excerpt text
  content_plain_text text
  normalized_search_text text
  topic varchar
  published_at timestamp
  featured bool
  views int
}

TableGroup "Search Source" [note: "Dữ liệu gốc được trích từ content module"] {
  posts_search_source
  post_search_source_tags
}

TableGroup "Async Runtime" [note: "Artifact runtime (dấu vết chạy nền) cho worker và queue"] {
  search_sync_jobs
}

TableGroup "Computed Index" [note: "Bản sao được tính ra để Meilisearch truy vấn nhanh"] {
  meilisearch_posts_index
}

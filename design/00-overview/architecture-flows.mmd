flowchart TD
    subgraph Flow1 ["Luồng 1: Đọc nội dung công khai"]
        F1A["Người dùng tải trang công khai"] --> F1B["apps/web gọi apps/api"]
        F1B --> F1C{"Nội dung đã xuất bản?"}
        F1C -->|"Không"| F1D["Trả về 404 hoặc 403 theo giao ước"]
        F1C -->|"Có"| F1E["apps/api đọc Postgres"]
        F1E --> F1F{"Bộ nhớ đệm dùng chung khả dụng?"}
        F1F -->|"Có"| F1G["Trả về mẫu dữ liệu đã đệm"]
        F1F -->|"Không"| F1H["Xây dựng phản hồi từ tài liệu chuẩn"]
        F1H --> F1I["Lưu đệm Redis (tùy chọn) cho lần đọc sau"]
        F1I --> F1J["Web hiển thị trang"]
    end

    subgraph Flow2 ["Luồng 2: Biên tập xuất bản, làm mới dữ liệu và đồng bộ tìm kiếm"]
        F2A["Biên tập viên xuất bản tài liệu trong admin"] --> F2B["apps/api ghi tài liệu chuẩn vào Postgres"]
        F2B --> F2C["Cập nhật publishedAt và các trường tìm kiếm"]
        F2C --> F2D["Đưa việc đồng bộ tìm kiếm vào hàng đợi"]
        F2C --> F2E["Kích hoạt làm mới web hoặc thu hồi bộ nhớ đệm"]
        F2D --> F2F["Worker cập nhật tài liệu vào Meilisearch"]
        F2E --> F2G["Luồng đọc công khai thấy nội dung mới"]
    end

    subgraph Flow3 ["Luồng 3: Cộng đồng gửi nội dung và cảnh báo kiểm duyệt"]
        F3A["Người dùng gửi bài viết, bình luận hoặc mục lưu bút"] --> F3B["apps/api kiểm tra và lưu trữ thực thể chuẩn"]
        F3B --> F3C["Thực thể bắt đầu ở trạng thái chờ kiểm duyệt"]
        F3C --> F3D["Ghi nhật ký kiểm toán (audit log) nếu cần"]
        F3D --> F3E["Tạo việc gửi thông báo/email cho kiểm duyệt viên và admin"]
    end

    subgraph Flow4 ["Luồng 4: Báo cáo vi phạm đến quyết định và đồng bộ tóm tắt"]
        F4A["Người dùng báo cáo thực thể"] --> F4B["Tạo bản ghi báo cáo vi phạm"]
        F4B --> F4C["Đồng bộ số lượt báo cáo và lý do cuối cùng vào mục tiêu"]
        F4C --> F4D["Kiểm duyệt viên xem xét báo cáo"]
        F4D --> F4E{"Quyết định"}
        F4E -->|"phê duyệt / gắn cờ / ẩn / từ chối"| F4F["Cập nhật trạng thái báo cáo vi phạm"]
        F4F --> F4G["Áp dụng tóm tắt kiểm duyệt vào thực thể mục tiêu"]
        F4G --> F4H["Tạo thông báo bất đồng bộ nếu cần"]
    end

    subgraph Flow5 ["Luồng 5: Đăng nhập bằng NestJS auth"]
        F5A["Người dùng gửi thông tin đăng nhập"] --> F5B["NestJS auth xác thực thông tin"]
        F5B --> F5C{"Hợp lệ?"}
        F5C -->|"Không"| F5D["Trả về 401"]
        F5C -->|"Có"| F5E["Tạo phiên hoặc cookie qua NestJS auth"]
        F5E --> F5F["Cập nhật lastLoginAt nếu cần"]
        F5F --> F5G["Web sử dụng giao ước phiên cho các yêu cầu kế tiếp"]
    end

    subgraph Flow6 ["Luồng 6: Truy vấn tìm kiếm có phương án dự phòng"]
        F6A["Web gọi điểm cuối tìm kiếm bài viết"] --> F6B["apps/api phân tích truy vấn và giới hạn"]
        F6B --> F6C{"Meilisearch khả dụng?"}
        F6C -->|"Có"| F6D["Tìm kiếm trên chỉ mục Meilisearch"]
        F6C -->|"Không"| F6E["Tìm kiếm dự phòng qua SQL/API"]
        F6D --> F6F["Ánh xạ kết quả sang DTO công khai"]
        F6E --> F6F
        F6F --> F6G["Trả về kết quả kèm đánh dấu engine"]
    end

    subgraph Flow7 ["Luồng 7: Điều phối thông báo đẩy"]
        F7A["Dịch vụ tạo bản ghi việc gửi thông báo"] --> F7B["Worker xử lý hàng đợi điều phối thông báo"]
        F7B --> F7C["Tìm các đăng ký đang hoạt động phù hợp"]
        F7C --> F7D["Gửi theo từng đợt (chunk)"]
        F7D --> F7E["Cập nhật số lượng gửi, thất bại và tóm tắt lỗi"]
        F7E --> F7F["Đánh dấu hoàn tất hoặc thất bại"]
    end

    subgraph Flow8 ["Luồng 8: Vòng lặp giám sát"]
        F8A["Web, API và Worker phát nhật ký và thông số"] --> F8B["Prometheus thu thập dữ liệu"]
        F8B --> F8C["Grafana hiển thị bảng điều khiển"]
        F8B --> F8D["Alertmanager đánh giá ngưỡng cảnh báo"]
        F8D --> F8E["Kênh cảnh báo nhận thông báo"]
    end

    F1J -.->|"tiếp"| F2A
    F2G -.->|"tiếp"| F3A
    F3E -.->|"tiếp"| F4A
    F4H -.->|"tiếp"| F5A
    F5G -.->|"tiếp"| F6A
    F6G -.->|"tiếp"| F7A
    F7F -.->|"tiếp"| F8A

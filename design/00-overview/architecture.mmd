graph TD
    subgraph "Điều phối truy cập (Ingress)"
        Caddy["Caddy<br/>proxy đảo / HTTPS"]
    end

    subgraph "Giao diện (Frontend)"
        Web["apps/web<br/>Next.js App Router"]
    end

    subgraph "Môi trường CMS (CMS Runtime)"
        CMS["apps/cms<br/>Payload admin + API + định danh"]
        Compat["Các luồng tương thích<br/>ánh xạ dữ liệu (DTO) công khai"]
        Proxy["Ranh giới web proxy<br/>kiểm soát yêu cầu/phiên"]
    end

    subgraph "Xử lý bất đồng bộ (Async Runtime)"
        Redis["Redis<br/>bộ nhớ đệm + hàng đợi + điều phối"]
        Worker["Worker<br/>đồng bộ tìm kiếm / thông báo / email / bảo trì"]
    end

    subgraph "Dữ liệu (Data)"
        Postgres["PostgreSQL<br/>nguồn dữ liệu chuẩn"]
        Meili["Meilisearch<br/>chỉ dành cho chỉ mục tìm kiếm"]
    end

    subgraph "Giám sát (Tùy chọn)"
        PgBouncer["PgBouncer"]
        Prometheus["Prometheus"]
        Grafana["Grafana"]
        Alertmanager["Alertmanager"]
    end

    Caddy --> Web
    Caddy --> CMS

    Web --> Proxy
    Proxy --> Compat
    Compat --> CMS

    CMS -->|đọc/ghi dữ liệu chuẩn| Postgres
    CMS -->|đệm / đưa việc vào hàng đợi| Redis
    Worker -->|lấy việc| Redis
    Worker -->|đọc/ghi dữ liệu chuẩn khi cần| Postgres
    Worker -->|cập nhật tài liệu tìm kiếm| Meili

    CMS -->|truy vấn tìm kiếm / trạng thái| Meili
    Web -->|tìm kiếm công khai qua CMS| Compat

    CMS -. tùy chọn .-> PgBouncer
    PgBouncer -. pool .-> Postgres

    Web -. thông số/nhật ký .-> Prometheus
    CMS -. thông số/nhật ký .-> Prometheus
    Worker -. thông số/nhật ký .-> Prometheus
    Prometheus --> Grafana
    Prometheus --> Alertmanager

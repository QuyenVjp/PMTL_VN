graph TD
    subgraph "Ingress"
        Caddy["Caddy<br/>reverse proxy / HTTPS"]
    end

    subgraph "Frontend"
        Web["apps/web<br/>Next.js App Router"]
    end

    subgraph "CMS Runtime"
        CMS["apps/cms<br/>Payload admin + API + auth"]
        Compat["Compatibility routes<br/>public DTO mapping"]
        Proxy["web proxy boundary<br/>request/session guards"]
    end

    subgraph "Async Runtime"
        Redis["Redis<br/>cache + queue + coordination"]
        Worker["Worker<br/>search sync / push / email / maintenance"]
    end

    subgraph "Data"
        Postgres["PostgreSQL<br/>source of truth"]
        Meili["Meilisearch<br/>search index only"]
    end

    subgraph "Optional Monitoring"
        PgBouncer["PgBouncer"]
        Prometheus["Prometheus"]
        Grafana["Grafana"]
        Alertmanager["Alertmanager"]
    end

    Caddy --> Web
    Caddy --> CMS

    Web --> Proxy
    Proxy --> Compat
    Compat --> CMS

    CMS -->|read/write canonical data| Postgres
    CMS -->|cache / enqueue jobs| Redis
    Worker -->|pull jobs| Redis
    Worker -->|read/write canonical data when needed| Postgres
    Worker -->|update search documents| Meili

    CMS -->|search queries / status| Meili
    Web -->|public search via CMS contract| Compat

    CMS -. optional .-> PgBouncer
    PgBouncer -. pool .-> Postgres

    Web -. metrics/logs .-> Prometheus
    CMS -. metrics/logs .-> Prometheus
    Worker -. metrics/logs .-> Prometheus
    Prometheus --> Grafana
    Prometheus --> Alertmanager

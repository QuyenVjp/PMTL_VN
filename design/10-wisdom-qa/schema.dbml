Project wisdom_qa_schema {
  database_type: "PostgreSQL"
  Note: '''
  Wisdom & QA schema (lược đồ dữ liệu) cho PMTL_VN.
  Cách đọc nhanh:
  - wisdom_entries = bài Bạch thoại, khai thị, Phật ngôn, bài pháp hội.
  - qa_entries = bài hỏi đáp đã chuẩn hóa để tra cứu.
  - authority_profiles = hồ sơ authority (chủ thể thẩm quyền nguồn) như Sư Phụ Lư Quân Hoành.
  - offline_bundles = metadata (siêu dữ liệu) gói tải ngoại tuyến.
  '''
}

Enum wisdom_source_type {
  baihua
  kaishi
  program_audio
  program_video
}

Enum baihua_book_kind {
  baihua_book
  baihua_video_discourse
  radio_lecture
}

Enum source_provenance_type {
  official_origin
  official_mirror
  community_volunteer_site
  community_translation
  community_annotation
  testimonial_or_claim
}

Enum review_status_type {
  source_verified
  translated_draft
  translated_reviewed
  human_review_required
}

Enum qa_type {
  metaphysics_qa
  buddhist_qa
}

Enum offline_bundle_type {
  baihua_series
  qa_favorites
  night_reading_pack
}

Table wisdom_entries {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  source_url varchar(512) [not null]
  source_site_label varchar(160)
  source_type wisdom_source_type [not null]
  source_provenance source_provenance_type [not null, default: 'official_origin']
  source_code varchar(64) [note: "Mã bài hoặc timestamp (mốc thời gian), ví dụ shuohua20140808 08:56"]
  source_language varchar(16) [not null, default: 'zh']
  title_original varchar(255) [not null]
  title_vietnamese varchar(255)
  summary_vietnamese text
  body_original text
  body_vietnamese text
  source_image_ref varchar(160) [note: "Ảnh hoặc screenshot (ảnh chụp màn hình) nguồn nếu cần peer review (đối chiếu chéo)"]
  translation_credit varchar(160) [note: "Người dịch hoặc nhóm dịch nếu policy (chính sách) cho phép"]
  review_status review_status_type [not null, default: 'source_verified']
  audio_ref varchar(64)
  video_ref varchar(64)
  speaker varchar(160)
  is_official boolean [not null, default: true]
  published_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table baihua_books {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  slug varchar(160) [not null, unique]
  source_url varchar(512) [not null]
  source_site_label varchar(160)
  source_provenance source_provenance_type [not null, default: 'official_origin']
  book_kind baihua_book_kind [not null]
  source_book_key varchar(160) [not null, unique]
  title_original varchar(255) [not null]
  title_vietnamese varchar(255)
  description_vietnamese text
  cover_image_ref varchar(160)
  full_book_audio_url varchar(512)
  review_status review_status_type [not null, default: 'source_verified']
  published_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table baihua_book_entries {
  id uuid [pk]
  baihua_book_id uuid [not null, ref: > baihua_books.id]
  wisdom_entry_id uuid [not null, ref: > wisdom_entries.id]
  chapter_number int [not null]
  source_chapter_label varchar(255)

  Indexes {
    (baihua_book_id, wisdom_entry_id) [unique]
    (baihua_book_id, chapter_number) [unique]
  }
}

Table baihua_audio_tracks {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  baihua_book_id uuid [ref: > baihua_books.id]
  wisdom_entry_id uuid [ref: > wisdom_entries.id]
  track_type varchar(32) [not null, note: "full_book_mp3 | chapter_mp3 | future_vi_voice"]
  source_audio_url varchar(512)
  duration_seconds int
  language varchar(16) [not null, default: 'zh']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table wisdom_entry_tags {
  id uuid [pk]
  wisdom_entry_id uuid [not null, ref: > wisdom_entries.id]
  tag varchar(64) [not null]

  Indexes {
    (wisdom_entry_id, tag) [unique]
  }
}

Table qa_entries {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  source_url varchar(512) [not null]
  source_site_label varchar(160)
  qa_type qa_type [not null]
  source_provenance source_provenance_type [not null, default: 'official_origin']
  source_code varchar(64) [note: "Mã bài hoặc timestamp (mốc thời gian), ví dụ shuohua20140808 08:56"]
  question_original text [not null]
  question_vietnamese text
  answer_original text [not null]
  answer_vietnamese text
  source_image_ref varchar(160) [note: "Ảnh hoặc screenshot (ảnh chụp màn hình) nguồn nếu cần peer review (đối chiếu chéo)"]
  translation_credit varchar(160) [note: "Người dịch hoặc nhóm dịch nếu policy (chính sách) cho phép"]
  review_status review_status_type [not null, default: 'source_verified']
  speaker varchar(160)
  is_official boolean [not null, default: true]
  published_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table authority_profiles {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  display_name_vi varchar(255) [not null]
  display_name_original varchar(255)
  source_url varchar(512)
  source_provenance source_provenance_type [not null, default: 'official_origin']
  official_fact_summary text [note: "Chỉ tóm tắt fact (sự kiện) có nguồn / official-source-backed facts"]
  translated_profile_summary text [note: "Bản giới thiệu tiếng Việt của cộng đồng / translated profile summary (phần giới thiệu đã dịch)"]
  doctrinal_claims text [note: "Claim tín ngưỡng hoặc doctrinal claims (khẳng định giáo nghĩa), tách riêng khỏi fact"]
  review_status review_status_type [not null, default: 'human_review_required']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table qa_entry_tags {
  id uuid [pk]
  qa_entry_id uuid [not null, ref: > qa_entries.id]
  tag varchar(64) [not null]

  Indexes {
    (qa_entry_id, tag) [unique]
  }
}

Table qa_entry_keyword_aliases {
  id uuid [pk]
  qa_entry_id uuid [not null, ref: > qa_entries.id]
  alias varchar(160) [not null]
  language varchar(16) [not null, default: 'vi']

  Indexes {
    (qa_entry_id, alias) [unique]
  }
}

Table offline_bundles {
  id uuid [pk]
  user_id uuid [note: "Null nếu hỗ trợ device-only bundle (gói chỉ gắn với thiết bị)"]
  device_key varchar(64)
  bundle_type offline_bundle_type [not null]
  version varchar(32) [not null]
  downloaded_at timestamptz
  last_synced_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table offline_bundle_items {
  id uuid [pk]
  offline_bundle_id uuid [not null, ref: > offline_bundles.id]
  entry_type varchar(16) [not null, note: "wisdom hoặc qa"]
  entry_public_id varchar(32) [not null]
  local_asset_key varchar(160)

  Indexes {
    (offline_bundle_id, entry_type, entry_public_id) [unique]
  }
}

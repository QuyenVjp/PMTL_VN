flowchart TD
    subgraph Flow1 ["Luồng 1: Gửi bài cộng đồng (Submit Community Post)"]
        U1A["Thành viên gửi bài (Member submits post)"] --> U1B["Kiểm tra nội dung (Validate content)"]
        U1B --> U1C["Chuẩn hóa ID, đường dẫn & ảnh chụp tác giả (Normalize ID, slug & snap)"]
        U1C --> U1D["Lưu bài đăng ở trạng thái Chờ duyệt (Save as pending)"]
        U1D --> U1E["Ghi nhật ký kiểm toán (Log audit)"]
        U1F["Thêm sự kiện báo cho quản trị viên (Append outbox alert)"]
    end

    U1F -.->|"tiếp (then)"| U2A

    subgraph Flow2 ["Luồng 2: Bình luận vào bài cộng đồng (Submit Community Comment)"]
        U2A["Thành viên gửi bình luận (Member submits comment)"] --> U2B["Tìm bài đăng đích (Find target post)"]
        U2B --> U2C{"Có bình luận cha? (Has parent?)"}
        U2C -->|"Có (Yes)"| U2D["Xác thực bình luận cha (Validate parent)"]
        U2C -->|"Không (No)"| U2E["Tạo bình luận cấp đầu (Top-level comment)"]
        U2D --> U2E
        U2E --> U2F["Lưu bình luận ở trạng thái Chờ duyệt (Save as pending)"]
        F2G["Cập nhật số lượng bình luận khi phê duyệt (Update counts on approval)"]
        U2F --> F2G
        F2G --> U2H["Thêm cảnh báo kiểm duyệt (Append moderation alert)"]
    end

    U2H -.->|"tiếp (then)"| U3A

    subgraph Flow3 ["Luồng 3: Bình luận bài biên tập (Post Comments)"]
        U3A["Gửi bình luận dưới bài viết (Submit post comment)"] --> U3B["Tìm bài viết theo ID/Slug (Find post)"]
        U3B --> U3C["Tạo bản ghi bình luận (Create postComments)"]
        U3D["Trạng thái mặc định là Chờ duyệt (Default to pending)"]
        U3C --> U3D
        U3E["Cập nhật số lượng khi được phê duyệt (Update count on approved)"]
        U3D --> U3E
    end

    U3E -.->|"tiếp (then)"| U4A

    subgraph Flow4 ["Luồng 4: Gửi sổ lưu niệm và báo cáo (Guestbook & Report)"]
        U4A["Gửi tin nhắn lưu niệm (Submit guestbook entry)"] --> U4B["Kiểm tra nội dung (Validate message)"]
        U4B --> U4C["Chuẩn hóa định danh & IP băm (Normalize ID & IP hash)"]
        U4D["Lưu ở trạng thái Chờ duyệt (Save as pending)"]
        U4C --> U4D
        U4E["Thêm thông báo cho quản trị viên (Append admin notify)"]
        U4D --> U4E
        U4F{"Có báo cáo vi phạm? (Submit report?)"}
        U4E --> U4F
        U4F -->|"Có (Yes)"| U4G["Tạo phiếu báo cáo kiểm duyệt (Create moderation report)"]
        U4F -->|"Không (No)"| U4H["Kết thúc (End)"]
    end

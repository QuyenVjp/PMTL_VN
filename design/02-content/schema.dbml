// Content Module - logical schema (Lược đồ logic Mô-đun Nội dung) aligned with current repo truth (khớp với thực trạng repo)
// Note:
// - Đây là lược đồ logic (logical schema), không phải bản sao vật lý của cơ sở dữ liệu.
// - Quy trình xuất bản (publish workflow) hiện bám sát trạng thái tường minh (status) và thời điểm xuất bản (published_at).
// - Hiện tại các bộ sưu tập nội dung biên tập (editorial collections) chưa có trường phân quyền hiển thị (visibility field) chung.
//   Nếu sau này cần tính năng nội dung giới hạn (gated content), trường `audience` (đối tượng) phải được thêm ở thực thể sở hữu tương ứng.

Project content_module {
  database_type: "PostgreSQL"
  Note: '''
  Content module cho PMTL_VN (Mô-đun Nội dung PMTL_VN).
  Gợi ý đọc nhanh (Quick guide):
  - Nhìn nhóm Editorial Content (Nội dung biên tập) trước.
  - Sau đó nhìn nhóm Practice Support (Hỗ trợ tu tập) nếu đang làm phần niệm kinh / nghi thức.
  - Sau đó nhìn nhóm Scripture Library (Thư viện kinh điển).
  - Cuối cùng nhìn nhóm Taxonomy and Shared References (Phân loại và Tham chiếu dùng chung).
  '''
}

Enum content_publication_status {
  draft [note: "Bản nháp"]
  published [note: "Đã xuất bản"]
}

Table users {
  id uuid [pk, note: "Khóa chính người dùng (tham chiếu)"]
  public_id varchar [unique, note: "ID công khai"]
  full_name varchar [note: "Họ tên đầy đủ"]
}

Table media_assets {
  id uuid [pk, note: "Khóa chính phương tiện"]
  public_id varchar [unique, note: "ID công khai"]
  storage_provider varchar [not null, note: "Bên cung cấp: local | s3-compatible"]
  object_key varchar [unique, not null, note: "Khóa đối tượng lưu trữ"]
  original_filename varchar [note: "Tên tệp gốc"]
  filename varchar [note: "Tên tệp lưu trữ"]
  mime_type varchar [note: "Loại tệp chuẩn"]
  content_type varchar [note: "Loại nội dung"]
  size_bytes bigint [note: "Kích thước tệp (bytes)"]
  checksum_sha256 varchar [note: "Mã kiểm tra tính toàn vẹn"]
  owner_id uuid [ref: > users.id, note: "Người tải lên"]
  created_at timestamp [note: "Thời điểm tạo"]
  updated_at timestamp [note: "Thời điểm cập nhật"]
}

Table categories {
  id uuid [pk, note: "Khóa chính danh mục"]
  public_id varchar [unique]
  name varchar [not null, note: "Tên danh mục"]
  slug varchar [unique, note: "Đường dẫn thân thiện cho SEO"]
  description text [note: "Mô tả danh mục"]
  created_at timestamp
  updated_at timestamp
}

Table tags {
  id uuid [pk, note: "Khóa chính thẻ"]
  public_id varchar [unique]
  name varchar [not null, note: "Tên thẻ"]
  slug varchar [unique]
  created_at timestamp
  updated_at timestamp
}

Table posts {
  id uuid [pk, note: "Khóa chính bài viết"]
  public_id varchar [unique]
  title varchar [not null, note: "Tiêu đề bài viết"]
  slug varchar [unique, not null, note: "Đường dẫn thân thiện"]
  post_type varchar [not null, note: "Loại bài: article | transcript | source-note | event-recap"]
  source_ref varchar [note: "Tham chiếu nguồn chính thống nếu có"]
  author_id uuid [ref: > users.id, note: "Mã biên tập viên"]
  primary_category_id uuid [ref: > categories.id]
  cover_media_id uuid [ref: > media_assets.id, note: "Ảnh bìa"]
  _status content_publication_status [not null, note: "Trạng thái xuất bản"]
  published_at timestamp [note: "Thời điểm xuất bản thực tế"]
  excerpt_override text [note: "Tóm tắt thủ công"]
  excerpt_computed text [note: "Tóm tắt tự động tính toán"]
  content jsonb [note: "Nội dung phong phú (Rich content)"]
  content_plain_text text [note: "Nội dung văn bản thô phục vụ tìm kiếm"]
  normalized_search_text text [note: "Văn bản đã chuẩn hóa phục vụ tìm kiếm"]
  featured bool [default: false, note: "Đánh dấu bài nổi bật"]
  allow_comments bool [default: true, note: "Cho phép bình luận"]
  comment_count int [default: 0, note: "Số lượng bình luận tổng hợp"]
  views int [default: 0, note: "Lượt xem tổng"]
  unique_views int [default: 0, note: "Lượt xem duy nhất"]
  likes int [default: 0, note: "Số lượt thích"]
  created_at timestamp
  updated_at timestamp
}

Table post_tags {
  post_id uuid [ref: > posts.id, note: "Mã bài viết"]
  tag_id uuid [ref: > tags.id, note: "Mã thẻ"]

  indexes {
    (post_id, tag_id) [pk]
  }
}

Table post_related_posts {
  post_id uuid [ref: > posts.id]
  related_post_id uuid [ref: > posts.id]

  indexes {
    (post_id, related_post_id) [pk]
  }
}

Table post_gallery_media {
  post_id uuid [ref: > posts.id]
  media_id uuid [ref: > media_assets.id]

  indexes {
    (post_id, media_id) [pk]
  }
}

Table hub_pages {
  id uuid [pk, note: "Khóa chính trang trung tâm"]
  public_id varchar [unique]
  title varchar [not null, note: "Tiêu đề trang"]
  slug varchar [unique, not null]
  description text [note: "Mô tả ngắn"]
  cover_media_id uuid [ref: > media_assets.id]
  visual_theme varchar [note: "Giao diện hiển thị"]
  show_in_menu bool [default: false, note: "Hiển thị trên trình đơn"]
  sort_order int [default: 0, note: "Thứ tự sắp xếp"]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table hub_page_blocks {
  id uuid [pk, note: "Khóa chính khối nội dung"]
  hub_page_id uuid [ref: > hub_pages.id]
  block_type varchar [not null, note: "Loại khối: text | post-grid | download-list..."]
  title varchar [note: "Tiêu đề khối"]
  content text [note: "Nội dung khối"]
  sort_order int [default: 0]
}

Table hub_page_curated_posts {
  hub_page_id uuid [ref: > hub_pages.id]
  post_id uuid [ref: > posts.id]

  indexes {
    (hub_page_id, post_id) [pk]
  }
}

Table beginner_guides {
  id uuid [pk, note: "Khóa chính hướng dẫn sơ học"]
  public_id varchar [unique]
  title varchar [not null, note: "Tiêu đề hướng dẫn"]
  description text
  content jsonb
  guide_type varchar [not null, note: "Loại: starter | practice | faq"]
  duration varchar [note: "Thời gian ước tính để hoàn thành"]
  step_number int [note: "Thứ tự bước (nếu có)"]
  order_no int [default: 0]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table beginner_guide_media {
  guide_id uuid [ref: > beginner_guides.id]
  media_id uuid [ref: > media_assets.id]
  usage_role varchar [note: "Vai trò sử dụng: image | attachment"]

  indexes {
    (guide_id, media_id, usage_role) [pk]
  }
}

Table downloads {
  id uuid [pk, note: "Khóa chính tài nguyên tải về"]
  public_id varchar [unique]
  title varchar [not null, note: "Tiêu đề tài nguyên"]
  description text
  file_media_id uuid [ref: > media_assets.id, note: "Tệp tin thực tế"]
  thumbnail_media_id uuid [ref: > media_assets.id, note: "Ảnh thu nhỏ"]
  external_url varchar [note: "Đường dẫn bên ngoài (nếu có)"]
  file_type varchar [note: "Loại tệp: pdf | mp3 | mp4..."]
  file_size_mb numeric [note: "Kích thước tệp (MB)"]
  category varchar [note: "Phân loại tải về"]
  group_year int [note: "Năm phát hành (phục vụ gom nhóm)"]
  group_label varchar [note: "Nhãn gom nhóm (ví dụ: Pháp hội Sydney)"]
  is_updating bool [default: false, note: "Đánh dấu đang cập nhật"]
  is_new bool [default: false, note: "Đánh dấu tài liệu mới"]
  sort_order int [default: 0]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table chant_items {
  id uuid [pk, note: "Khóa chính bài niệm/kinh lẻ"]
  public_id varchar [unique]
  title varchar [not null, note: "Tiêu đề bài niệm"]
  slug varchar [unique]
  kind varchar [not null, note: "Loại: chú, kinh, nghi thức mở đầu, mẫu lời khấn..."]
  opening_prayer text [note: "Lời khấn nguyện trước khi tụng"]
  content jsonb [note: "Kịch bản (script) hoặc nội dung văn bản chính"]
  audio_media_id uuid [ref: > media_assets.id, note: "Tệp âm thanh chuẩn"]
  script_file_media_id uuid [ref: > media_assets.id, note: "Tệp kịch bản (ví dụ PDF)"]
  created_at timestamp
  updated_at timestamp
}

Table chant_item_preview_media {
  chant_item_id uuid [ref: > chant_items.id]
  media_id uuid [ref: > media_assets.id]

  indexes {
    (chant_item_id, media_id) [pk]
  }
}

Table chant_item_recommended_presets {
  id uuid [pk, note: "Khóa chính bộ số biến gợi ý"]
  chant_item_id uuid [ref: > chant_items.id]
  label varchar [note: "Nhãn gợi ý (ví dụ: Bình thường, Trọng bệnh)"]
  target int [note: "Số biến mục tiêu"]
}

Table chant_item_time_rules {
  id uuid [pk, note: "Khóa chính quy tắc thời gian"]
  chant_item_id uuid [ref: > chant_items.id]
  date_from date [note: "Áp dụng từ ngày"]
  date_to date [note: "Áp dụng đến ngày"]
  lunar_day int [note: "Áp dụng cho ngày âm lịch cụ thể"]
  notes varchar [note: "Ghi chú quy tắc"]
}

Table chant_plans {
  id uuid [pk, note: "Khóa chính nghi thức/kế hoạch"]
  public_id varchar [unique]
  title varchar [not null, note: "Tiêu đề nghi thức"]
  slug varchar [unique]
  plan_type varchar [not null, note: "Loại: công khóa hằng ngày, phóng sinh, Ngôi Nhà Nhỏ..."]
  created_at timestamp
  updated_at timestamp
}

Table chant_plan_items {
  id uuid [pk, note: "Khóa chính thành phần nghi thức"]
  chant_plan_id uuid [ref: > chant_plans.id]
  chant_item_id uuid [ref: > chant_items.id]
  target int [note: "Số biến quy định trong nghi thức"]
  is_optional bool [default: false, note: "Dấu đánh thành phần tùy chọn"]
}

Table sutras {
  id uuid [pk, note: "Khóa chính kinh văn gốc"]
  public_id varchar [unique]
  title varchar [not null, note: "Tên bộ kinh"]
  slug varchar [unique, not null]
  description text
  short_excerpt text [note: "Đoạn trích ngắn"]
  cover_media_id uuid [ref: > media_assets.id]
  translator varchar [note: "Tên dịch giả"]
  reviewer varchar [note: "Tên người hiệu đính"]
  is_featured bool [default: false]
  sort_order int [default: 0]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table sutra_tags {
  sutra_id uuid [ref: > sutras.id]
  tag_id uuid [ref: > tags.id]

  indexes {
    (sutra_id, tag_id) [pk]
  }
}

Table sutra_volumes {
  id uuid [pk, note: "Khóa chính quyển kinh"]
  public_id varchar [unique]
  sutra_id uuid [not null, ref: > sutras.id]
  title varchar [not null, note: "Tên quyển"]
  volume_number int [not null, note: "Số thứ tự quyển"]
  description text
  book_start varchar [note: "Trang bắt đầu (để đối soát bản in)"]
  book_end varchar [note: "Trang kết thúc"]
  sort_order int [default: 0]
}

Table sutra_chapters {
  id uuid [pk, note: "Khóa chính chương kinh"]
  public_id varchar [unique]
  sutra_id uuid [not null, ref: > sutras.id]
  volume_id uuid [ref: > sutra_volumes.id]
  title varchar [not null, note: "Tên chương"]
  slug varchar [unique, not null]
  chapter_number int [not null]
  opening_text text [note: "Lời dẫn đầu chương"]
  ending_text text [note: "Lời kết chương"]
  content jsonb [note: "Nội dung văn bản chương kinh"]
  estimated_read_minutes int [note: "Thời gian đọc ước tính"]
  sort_order int [default: 0]
}

Table sutra_glossary {
  id uuid [pk, note: "Khóa chính thuật ngữ"]
  public_id varchar [unique]
  sutra_id uuid [not null, ref: > sutras.id]
  volume_id uuid [ref: > sutra_volumes.id]
  chapter_id uuid [ref: > sutra_chapters.id]
  term varchar [not null, note: "Từ vựng/Thuật ngữ"]
  meaning text [not null, note: "Ý nghĩa giải thích"]
  marker_key varchar [note: "Mã định danh để neo trong văn bản"]
  sort_order int [default: 0]
}

TableGroup "Editorial Content" [note: "Nhóm Nội dung biên tập công khai"] {
  posts
  hub_pages
  hub_page_blocks
  beginner_guides
  downloads
}

TableGroup "Practice Support" [note: "Nhóm Hỗ trợ tu tập: Bài niệm, kế hoạch, quy tắc, hướng dẫn nghi thức"] {
  chant_items
  chant_item_preview_media
  chant_item_recommended_presets
  chant_item_time_rules
  chant_plans
  chant_plan_items
}

TableGroup "Editorial Relations" [note: "Các bảng quan hệ phụ trợ cho nội dung biên tập"] {
  post_tags
  post_related_posts
  post_gallery_media
  hub_page_curated_posts
  beginner_guide_media
}

TableGroup "Scripture Library" [note: "Nhóm Thư viện kinh điển và cấu trúc đọc kinh"] {
  sutras
  sutra_tags
  sutra_volumes
  sutra_chapters
  sutra_glossary
}

TableGroup "Taxonomy and Shared References" [note: "Nhóm tham chiếu dùng chung cho toàn bộ mô-đun"] {
  users
  media_assets
  categories
  tags
}

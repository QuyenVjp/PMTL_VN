// Content Module - logical schema aligned with current repo truth
// Note:
// - Đây là schema thiết kế ở mức logical, không phải dump DB vật lý từ Payload.
// - Workflow publish hiện bám Payload drafts (_status) + published_at.
// - Repo hiện chưa materialize một field visibility chung cho toàn bộ editorial collections.
//   Nếu sau này cần gated content, field audience phải được thêm ở collection owner tương ứng.

Project content_module {
  database_type: "PostgreSQL"
  Note: '''
  Content module cho PMTL_VN.
  Gợi ý đọc nhanh:
  - Nhìn nhóm Editorial trước.
  - Sau đó nhìn nhóm Practice Support nếu anh đang làm phần niệm kinh / nghi thức.
  - Sau đó nhìn nhóm Scripture.
  - Cuối cùng nhìn nhóm Taxonomy và Media.
  '''
}

Enum content_publication_status {
  draft
  published
}

Table users {
  id uuid [pk]
  public_id varchar [unique]
  full_name varchar
}

Table media_assets {
  id uuid [pk]
  public_id varchar [unique]
  filename varchar
  mime_type varchar
  created_at timestamp
  updated_at timestamp
}

Table categories {
  id uuid [pk]
  public_id varchar [unique]
  name varchar [not null]
  slug varchar [unique]
  description text
  created_at timestamp
  updated_at timestamp
}

Table tags {
  id uuid [pk]
  public_id varchar [unique]
  name varchar [not null]
  slug varchar [unique]
  created_at timestamp
  updated_at timestamp
}

Table posts {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  slug varchar [unique, not null]
  post_type varchar [not null] // article | transcript | source-note | event-recap
  source_ref varchar
  author_id uuid [ref: > users.id]
  primary_category_id uuid [ref: > categories.id]
  cover_media_id uuid [ref: > media_assets.id]
  _status content_publication_status [not null]
  published_at timestamp
  excerpt_override text
  excerpt_computed text
  content jsonb
  content_plain_text text
  normalized_search_text text
  featured bool [default: false]
  allow_comments bool [default: true]
  comment_count int [default: 0]
  views int [default: 0]
  unique_views int [default: 0]
  likes int [default: 0]
  created_at timestamp
  updated_at timestamp
}

Table post_tags {
  post_id uuid [ref: > posts.id]
  tag_id uuid [ref: > tags.id]

  indexes {
    (post_id, tag_id) [pk]
  }
}

Table post_related_posts {
  post_id uuid [ref: > posts.id]
  related_post_id uuid [ref: > posts.id]

  indexes {
    (post_id, related_post_id) [pk]
  }
}

Table post_gallery_media {
  post_id uuid [ref: > posts.id]
  media_id uuid [ref: > media_assets.id]

  indexes {
    (post_id, media_id) [pk]
  }
}

Table hub_pages {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  slug varchar [unique, not null]
  description text
  cover_media_id uuid [ref: > media_assets.id]
  visual_theme varchar
  show_in_menu bool [default: false]
  sort_order int [default: 0]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table hub_page_blocks {
  id uuid [pk]
  hub_page_id uuid [ref: > hub_pages.id]
  block_type varchar [not null]
  title varchar
  content text
  sort_order int [default: 0]
}

Table hub_page_curated_posts {
  hub_page_id uuid [ref: > hub_pages.id]
  post_id uuid [ref: > posts.id]

  indexes {
    (hub_page_id, post_id) [pk]
  }
}

Table beginner_guides {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  description text
  content jsonb
  guide_type varchar [not null] // starter | practice | faq
  duration varchar
  step_number int
  order_no int [default: 0]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table beginner_guide_media {
  guide_id uuid [ref: > beginner_guides.id]
  media_id uuid [ref: > media_assets.id]
  usage_role varchar // image | attachment

  indexes {
    (guide_id, media_id, usage_role) [pk]
  }
}

Table downloads {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  description text
  file_media_id uuid [ref: > media_assets.id]
  thumbnail_media_id uuid [ref: > media_assets.id]
  external_url varchar
  file_type varchar
  file_size_mb numeric
  category varchar
  group_year int
  group_label varchar
  is_updating bool [default: false]
  is_new bool [default: false]
  sort_order int [default: 0]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table chant_items {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  slug varchar [unique]
  kind varchar [not null, note: "Ví dụ: chú, kinh, opening-ritual, prayer-template"]
  opening_prayer text
  content jsonb [note: "Script hoặc rich content chính"]
  audio_media_id uuid [ref: > media_assets.id]
  script_file_media_id uuid [ref: > media_assets.id]
  created_at timestamp
  updated_at timestamp
}

Table chant_item_preview_media {
  chant_item_id uuid [ref: > chant_items.id]
  media_id uuid [ref: > media_assets.id]

  indexes {
    (chant_item_id, media_id) [pk]
  }
}

Table chant_item_recommended_presets {
  id uuid [pk]
  chant_item_id uuid [ref: > chant_items.id]
  label varchar
  target int
}

Table chant_item_time_rules {
  id uuid [pk]
  chant_item_id uuid [ref: > chant_items.id]
  date_from date
  date_to date
  lunar_day int
  notes varchar
}

Table chant_plans {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  slug varchar [unique]
  plan_type varchar [not null, note: "Ví dụ: daily-recitation, life-release, little-house"]
  created_at timestamp
  updated_at timestamp
}

Table chant_plan_items {
  id uuid [pk]
  chant_plan_id uuid [ref: > chant_plans.id]
  chant_item_id uuid [ref: > chant_items.id]
  target int
  is_optional bool [default: false]
}

Table sutras {
  id uuid [pk]
  public_id varchar [unique]
  title varchar [not null]
  slug varchar [unique, not null]
  description text
  short_excerpt text
  cover_media_id uuid [ref: > media_assets.id]
  translator varchar
  reviewer varchar
  is_featured bool [default: false]
  sort_order int [default: 0]
  _status content_publication_status [not null]
  created_at timestamp
  updated_at timestamp
}

Table sutra_tags {
  sutra_id uuid [ref: > sutras.id]
  tag_id uuid [ref: > tags.id]

  indexes {
    (sutra_id, tag_id) [pk]
  }
}

Table sutra_volumes {
  id uuid [pk]
  public_id varchar [unique]
  sutra_id uuid [not null, ref: > sutras.id]
  title varchar [not null]
  volume_number int [not null]
  description text
  book_start varchar
  book_end varchar
  sort_order int [default: 0]
}

Table sutra_chapters {
  id uuid [pk]
  public_id varchar [unique]
  sutra_id uuid [not null, ref: > sutras.id]
  volume_id uuid [ref: > sutra_volumes.id]
  title varchar [not null]
  slug varchar [unique, not null]
  chapter_number int [not null]
  opening_text text
  ending_text text
  content jsonb
  estimated_read_minutes int
  sort_order int [default: 0]
}

Table sutra_glossary {
  id uuid [pk]
  public_id varchar [unique]
  sutra_id uuid [not null, ref: > sutras.id]
  volume_id uuid [ref: > sutra_volumes.id]
  chapter_id uuid [ref: > sutra_chapters.id]
  term varchar [not null]
  meaning text [not null]
  marker_key varchar
  sort_order int [default: 0]
}

TableGroup "Editorial Content" [note: "Nội dung biên tập công khai hoặc bán công khai"] {
  posts
  hub_pages
  hub_page_blocks
  beginner_guides
  downloads
}

TableGroup "Practice Support" [note: "Nội dung hỗ trợ niệm: bài niệm, plan, rule, media, ritual guide"] {
  chant_items
  chant_item_preview_media
  chant_item_recommended_presets
  chant_item_time_rules
  chant_plans
  chant_plan_items
}

TableGroup "Editorial Relations" [note: "Bảng nối và quan hệ phụ trợ cho editorial"] {
  post_tags
  post_related_posts
  post_gallery_media
  hub_page_curated_posts
  beginner_guide_media
}

TableGroup "Scripture Library" [note: "Thư viện kinh và cây đọc kinh"] {
  sutras
  sutra_tags
  sutra_volumes
  sutra_chapters
  sutra_glossary
}

TableGroup "Taxonomy and Shared References" [note: "Dùng chung cho nhiều collection content"] {
  users
  media_assets
  categories
  tags
}

flowchart TD
    subgraph Flow1 ["Luồng 1: Biên tập và xuất bản bài viết"]
        C1A["Biên tập viên tạo hoặc mở bài viết trong posts"] --> C1B["Nhập title, content, taxonomy, và media"]
        C1B --> C1C["Chuẩn hóa slug, excerpt, plain text, và normalized search text"]
        C1C --> C1D{"Payload _status"}
        C1D -->|"draft"| C1E["Lưu bản nháp"]
        C1D -->|"published"| C1F["Thiết lập publishedAt nếu chưa có"]
        C1E --> C1G["Biên tập viên tiếp tục chỉnh sửa"]
        C1G --> C1D
        C1F --> C1H["Public route có thể đọc document"]
        C1F --> C1I["Đưa search sync vào hàng chờ"]
        C1F --> C1J["Kích hoạt revalidation hoặc invalidation"]
    end

    subgraph Flow2 ["Luồng 2: Cập nhật nội dung đã publish"]
        C2A["Biên tập viên sửa nội dung đã published"] --> C2B["Lưu thay đổi"]
        C2B --> C2C["Cập nhật excerpt, search fields, và derived data"]
        C2C --> C2D{"Document còn published không?"}
        C2D -->|"Có"| C2E["Đưa search sync update vào hàng chờ"]
        C2D -->|"Không"| C2F["Search document (bản ghi tìm kiếm) bị gỡ hoặc không còn public"]
        C2E --> C2G["Làm mới public cache liên quan"]
        C2F --> C2G
    end

    subgraph Flow3 ["Luồng 3: Xây và cập nhật thư viện kinh"]
        C3A["Tạo sutra root"] --> C3B["Tạo volumes"]
        C3B --> C3C["Tạo chapters"]
        C3C --> C3D["Tạo glossary entries"]
        C3D --> C3E["Liên kết cover image, tags, và metadata"]
        C3E --> C3F{"Sutra published?"}
        C3F -->|"Chưa"| C3G["Tiếp tục biên tập"]
        C3F -->|"Rồi"| C3H["Public tree đọc kinh khả dụng"]
    end

    subgraph Flow4 ["Luồng 4: Public đọc nội dung và tìm kiếm"]
        C4A["Web gọi compatibility route"] --> C4B{"Loại nội dung"}
        C4B -->|"Post hoặc Hub hoặc Guide hoặc Download"| C4C["CMS ánh xạ document sang public DTO"]
        C4B -->|"Sutra tree"| C4D["CMS trả root hoặc chapter DTO"]
        C4C --> C4E["Web render"]
        C4D --> C4E
        C4E --> C4F{"Người dùng có tìm kiếm post không?"}
        C4F -->|"Có"| C4G["Search module thực hiện truy vấn Meilisearch"]
        C4G --> C4H{"Meilisearch khả dụng không?"}
        C4H -->|"Có"| C4I["Trả kết quả từ index"]
        C4H -->|"Không"| C4J["Fallback query qua Payload"]
        C4F -->|"Không"| C4K["Kết thúc"]
    end

    C1J -.->|"tiếp"| C2A
    C2G -.->|"tiếp"| C3A
    C3H -.->|"tiếp"| C4A

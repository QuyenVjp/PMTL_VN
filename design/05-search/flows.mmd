flowchart TD
    subgraph Flow1 ["Luồng 1: Xuất bản nội dung và đưa đồng bộ tìm kiếm vào hàng chờ"]
        S1A["Content document được publish hoặc update (xuất bản hoặc cập nhật)"] --> S1B["Owner service chuẩn hóa search fields (các trường tìm kiếm)"]
        S1B --> S1C["Đưa search-sync job vào queue (hàng chờ)"]
        S1C --> S1D["Worker nhận job"]
        S1D --> S1E["Build search document (tạo bản ghi tìm kiếm)"]
        S1E --> S1F["Upsert vào Meilisearch posts index (chỉ mục bài viết)"]
    end

    subgraph Flow2 ["Luồng 2: Tìm kiếm công khai"]
        S2A["Web gọi posts search endpoint"] --> S2B["API parse query và limit"]
        S2B --> S2C{"Meilisearch available? (Meilisearch có sẵn không?)"}
        S2C -->|"Có"| S2D["Tìm trong search index của posts"]
        S2C -->|"Không"| S2E["Fallback query qua SQL/API"]
        S2D --> S2F["Map kết quả sang public DTO"]
        S2E --> S2F
        S2F --> S2G["Trả engine marker cùng kết quả"]
    end

    subgraph Flow3 ["Luồng 3: Đánh lại chỉ mục theo lô"]
        S3A["Biên tập viên gọi reindex endpoint (điểm cuối đánh lại chỉ mục)"] --> S3B["API đọc batch posts"]
        S3B --> S3C["Đưa nhiều search-sync jobs vào queue"]
        S3C --> S3D["Worker xử lý queue"]
        S3D --> S3E["Status endpoint phản ánh queue counts và index health (sức khỏe chỉ mục)"]
    end

    S1F -.->|"tiếp"| S2A
    S2G -.->|"tiếp"| S3A

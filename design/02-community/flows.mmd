flowchart TD
    subgraph Flow1 ["Luồng 1: Gửi bài cộng đồng"]
        U1A["Member gửi community post"] --> U1B["CMS validate title, content, và type"]
        U1B --> U1C["Chuẩn hóa publicId, slug, author snapshot, và spamScore"]
        U1C --> U1D["Lưu communityPosts với moderationStatus mặc định pending"]
        U1D --> U1E["Append audit log"]
        U1E --> U1F["Enqueue alert cho moderator hoặc admin"]
    end

    subgraph Flow2 ["Luồng 2: Bình luận vào bài cộng đồng"]
        U2A["Member gửi bình luận"] --> U2B["Tìm community post đích"]
        U2B --> U2C{"Có parent comment?"}
        U2C -->|"Có"| U2D["Xác thực parent thuộc cùng post"]
        U2C -->|"Không"| U2E["Tạo comment top-level"]
        U2D --> U2E
        U2E --> U2F["Lưu communityComments với moderationStatus pending"]
        U2F --> U2G["Tính lại commentsCount khi comment được duyệt"]
        U2G --> U2H["Enqueue alert moderation nếu cần"]
    end

    subgraph Flow3 ["Luồng 3: Bình luận vào bài viết editorial"]
        U3A["Người dùng gửi post comment"] --> U3B["Tìm post theo publicId hoặc slug"]
        U3B --> U3C["Tạo postComments"]
        U3C --> U3D["Comment có moderationStatus pending"]
        U3D --> U3E["Khi approved thì recompute commentCount cho post"]
    end

    subgraph Flow4 ["Luồng 4: Guestbook submit và report"]
        U4A["Khách hoặc member gửi guestbook entry"] --> U4B["Validate message"]
        U4B --> U4C["Chuẩn hóa publicId, ip hash, badge, và country nếu có"]
        U4C --> U4D["Lưu guestbookEntries với approvalStatus pending"]
        U4D --> U4E["Notify moderator hoặc admin"]
        U4E --> U4F{"Người dùng report entity?"}
        U4F -->|"Có"| U4G["Tạo moderation report"]
        U4F -->|"Không"| U4H["Kết thúc"]
    end

    U1F -.->|"tiếp"| U2A
    U2H -.->|"tiếp"| U3A
    U3E -.->|"tiếp"| U4A

Project ngoihanho_schema {
  database_type: "PostgreSQL"
  Note: "Schema logic de xuat cho self-owned Ngoi Nha Nho support."
}

Enum ngoihanho_sheet_status {
  draft
  in_progress
  completed
  self_stored
  offered
}

Enum ngoihanho_sheet_type {
  standard
  self_store
  custom
}

Enum ngoihanho_counter_type {
  great_compassion
  heart_sutra
  rebirth_mantra
  seven_buddhas
}

Table ngoihanho_sheets {
  id uuid [pk]
  public_id varchar(32) [not null, unique]
  user_id uuid [not null, note: "Refers to identity.users"]
  sheet_type ngoihanho_sheet_type [not null, default: 'standard']
  title_snapshot varchar(160)
  template_ref varchar(64) [note: "Refers to content chant item/plan template"]
  dedication_target_snapshot text
  practice_date date
  status ngoihanho_sheet_status [not null, default: 'draft']
  required_great_compassion_count int [not null, default: 0]
  required_heart_sutra_count int [not null, default: 0]
  required_rebirth_mantra_count int [not null, default: 0]
  required_seven_buddhas_count int [not null, default: 0]
  current_great_compassion_count int [not null, default: 0]
  current_heart_sutra_count int [not null, default: 0]
  current_rebirth_mantra_count int [not null, default: 0]
  current_seven_buddhas_count int [not null, default: 0]
  last_client_event_id varchar(64)
  notes text
  started_at timestamptz
  completed_at timestamptz
  offered_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: "Canonical self-owned sheet record. Counters may be embedded for phase 1."
}

Table ngoihanho_sheet_entries {
  id uuid [pk]
  sheet_id uuid [not null, ref: > ngoihanho_sheets.id]
  client_event_id varchar(64) [not null]
  counter_type ngoihanho_counter_type [not null]
  delta int [not null, default: 1]
  created_at timestamptz [not null]

  Indexes {
    (sheet_id, client_event_id) [unique]
  }

  Note: "Optional event table for anti-duplicate and audit-grade progress trace."
}

Table ngoihanho_sheet_audit_snapshots {
  id uuid [pk]
  sheet_id uuid [not null, ref: > ngoihanho_sheets.id]
  action varchar(64) [not null]
  before_status ngoihanho_sheet_status
  after_status ngoihanho_sheet_status
  actor_user_id uuid
  created_at timestamptz [not null]

  Note: "Compact state milestones; detailed auditLogs still live in audit module."
}

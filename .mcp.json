{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "postgres-pmtl": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${POSTGRES_PMTL_MCP_URL:-postgresql://postgres:postgres@127.0.0.1:55432/postgres}"
      ]
    }
  }
}
